# Git ignore rules - normal blacklist mode
# Keep source/config files tracked by default; ignore only generated/dependency/local files.

# OS / editor
.DS_Store
Thumbs.db
*.lnk
desktop.ini

# Python / backend
backend/__pycache__/
backend/*.pyc
backend/.venv/
backend/.env
backend/test_backend.py
backend/test_sync.py
backend/test_wak.py
__pycache__/
*.py[cod]

# Frontend / Node
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.eslintcache
frontend/playwright-report/
frontend/test-results/

# Generated / local data
*.tmp
*.temp
*.bak
*.orig
noitadata/
bin/
build/
dist/

# Logs / temp / reports
*.log
*.diff
changes_report.md
review.diff
current_changes.diff
diff.txt
spell_meta_errors.txt
static_prepare_errors.txt

# IDE / tool local folders
.vscode/
.claude/

# Project-specific local scripts or transient files
scripts/.dev_version_counter.json
frontend/dist_backup/
old/
StonesFromAnother/
biao/

# Local-only assets or outputs (keep out of main repo)
ghpages/
pic/
docs/
*.bat
tools/
frontend/public/static_data/



# Submodule transient files
wand_eval_tree/checkpoint.json
wand_eval_tree/single_test.lua

# Backup / temporary script versions
202*-*-* *.txt
